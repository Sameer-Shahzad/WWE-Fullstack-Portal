generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Superstar {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  brand     String   
  image     String
  height    String?  
  weight    String? 
  intro     String
  bio       String?
  createdAt DateTime @default(now())
}